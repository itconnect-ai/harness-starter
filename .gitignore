node_modules/
.pnp
.pnp.js

# Build
dist/
build/
.next/
out/
*.tsbuildinfo

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# State (template은 유지, 실행 결과는 제외)
state/epic-*-progress.json
state/validate/
.gh-codex/

# Review logs (리뷰 결과는 유지, 로그는 제외)
reviews/*/logs/

# Claude Code local settings
.claude/settings.local.json

# Serena cache
.serena/cache/

# Test coverage
coverage/
.nyc_output/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Organization-specific info (contains internal IPs, domains, backup paths)
# template 파일(.template.md)은 커밋, 실제 값 파일은 제외
docs/org/docker-port-registry.md
docs/org/*.local.md

# private/: 외부 공개 금지 내부 정보 (README.md만 커밋)
private/*
!private/README.md

# DB 마이그레이션 전 자동 백업 (db-migrate.sh가 생성)
state/db-backups/
