#!/usr/bin/env bash
# ============================================================================
# .githooks/commit-msg
#
# Commit 메시지 형식 검증 (Conventional Commits).
# 통과 조건: 첫 줄이 'type(scope): description' 패턴이거나 merge/revert 등 특수 커밋.
# ============================================================================
set -e

COMMIT_MSG_FILE="$1"
FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")

# 빈 커밋 메시지나 주석 줄 무시
if [ -z "$FIRST_LINE" ] || [[ "$FIRST_LINE" == \#* ]]; then
  exit 0
fi

# 특수 커밋은 형식 검증 건너뜀
if echo "$FIRST_LINE" | grep -qE '^(Merge |Revert |fixup!|squash!|amend!|Initial commit)'; then
  exit 0
fi

# Conventional commit 형식 검증
# type: feat, fix, refactor, test, docs, chore, perf, style, ci, build
# scope: optional, [a-z0-9_-]+ or [a-z0-9_/-]+
if ! echo "$FIRST_LINE" | grep -qE '^(feat|fix|refactor|test|docs|chore|perf|style|ci|build)(\([a-z0-9_/-]+\))?!?: .+'; then
  cat >&2 <<EOF
ERROR: Commit 메시지가 Conventional Commits 형식이 아닙니다.

형식: type(scope): description
  허용 type: feat, fix, refactor, test, docs, chore, perf, style, ci, build
  scope: 소문자/숫자/하이픈/슬래시 (선택)

예시:
  feat(auth): JWT refresh token 추가
  fix(validate): base ref 탐색 순서 수정
  chore(harness): feedback-rules 승격

현재 메시지:
  $FIRST_LINE
EOF
  exit 1
fi

exit 0
